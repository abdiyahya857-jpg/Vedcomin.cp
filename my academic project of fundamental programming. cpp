 >>>SOLUTION!*/
 
      
#include <iostream>
using namespace std;

int main() {
    int n;
    cout << "Enter size: ";
    cin >> n;

    if (n < 2) {
        cout << "Size must >=2!";
        return 0;
    }

    double arr[n];
    cout << "Enter elements:\n";
    for (int i = 0; i < n; i++)
        cin >> arr[i];

    double max = arr[0];
    for (int i = 1; i < n; i++)
        if (arr[i] > max)
            max = arr[i];

    double second = arr[0];
    for (int i = 0; i < n; i++) {
        if (arr[i] < max && (second == max || arr[i] > second))
            second = arr[i];
    }

    if (second == max)
        cout << "No second largest (all equal)";
    else
        cout << "Second largest: " << second;

    return 0;}
    
   
